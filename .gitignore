# local endpoint roster (machine-specific; targets.example.yaml is the template)
targets.yaml

# results are BOX-PRIVATE (which models live on which machine, endpoints,
# scores) — never publish with the engine. Share only deliberately-sanitized
# copies (no base_urls, no private model rosters).
scorecards/*
!scorecards/.gitkeep

# python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# secrets — never committed; env vars are the real channel
.env
.env.*

# editable-install / build artifacts
*.egg-info/
build/
dist/

# any local private config that strays into the tree
targets.local.yaml
